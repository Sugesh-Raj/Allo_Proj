# Hosted PostgreSQL database connection string (Supabase, Neon, Railway, etc.)
DATABASE_URL="postgresql://username:password@hostname:5432/dbname?sslmode=require"

# Secret key for signing HttpOnly JWT session cookies (can be any long random string)
JWT_SECRET="allo_health_super_secret_session_jwt_key_12345!"

# Secret token required to trigger the cron endpoint /api/cron/release-expired via header: Authorization: Bearer <CRON_SECRET>
CRON_SECRET="allo_health_cron_secret_token_12345!"
