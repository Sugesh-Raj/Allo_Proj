datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  SHIPPED
  RELEASED
}

enum Role {
  USER
  ADMIN
}

enum TransactionType {
  STOCK_ADJUSTMENT
  STOCK_TRANSFER
  RESERVATION_HOLD
  RESERVATION_CONFIRM
  RESERVATION_RELEASE
}

model User {
  id           String        @id @default(uuid())
  email        String        @unique
  passwordHash String
  name         String
  role         Role          @default(USER)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  reservations Reservation[]
}

model Product {
  id          String        @id @default(uuid())
  name        String
  sku         String        @unique
  price       Decimal       @db.Decimal(10, 2)
  imageUrl    String?
  description String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  inventories Inventory[]
  reservations Reservation[]
  auditLogs    InventoryAuditLog[]
}

model Warehouse {
  id          String        @id @default(uuid())
  name        String
  location    String
  region      String        // e.g. NA, EU, APAC
  inventories Inventory[]
  reservations Reservation[]
  auditLogsFrom InventoryAuditLog[] @relation("WarehouseFrom")
  auditLogsTo   InventoryAuditLog[] @relation("WarehouseTo")
}

model Inventory {
  productId   String
  warehouseId String
  total       Int          // Total physical units
  reserved    Int          // Count of units currently held in PENDING reservations

  product     Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouse   Warehouse    @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@id([productId, warehouseId])
  @@index([productId, warehouseId])
}

model Reservation {
  id             String            @id @default(uuid())
  userId         String
  productId      String
  warehouseId    String
  quantity       Int
  status         ReservationStatus @default(PENDING)
  expiresAt      DateTime
  idempotencyKey String?           @unique
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  product        Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouse      Warehouse         @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@index([expiresAt, status])
}

model InventoryAuditLog {
  id              String          @id @default(uuid())
  productId       String
  fromWarehouseId String?
  toWarehouseId   String?
  quantity        Int
  type            TransactionType
  notes           String?
  createdAt       DateTime        @default(now())

  product         Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  fromWarehouse   Warehouse?      @relation("WarehouseFrom", fields: [fromWarehouseId], references: [id], onDelete: Cascade)
  toWarehouse     Warehouse?      @relation("WarehouseTo", fields: [toWarehouseId], references: [id], onDelete: Cascade)
}

model IdempotencyRecord {
  key            String   @id
  responseStatus Int
  responseBody   String   // JSON string of response
  createdAt      DateTime @default(now())
}
